# OpenAI API Key — required for both the Code Explainer app and DeepEval metrics
OPENAI_API_KEY=your-openai-api-key-here

# Model configuration
CODE_EXPLAINER_MODEL=gpt-4o-mini
EVAL_MODEL=gpt-4o-mini

# Quality thresholds (0.0 - 1.0)
CORRECTNESS_THRESHOLD=0.85
RELEVANCY_THRESHOLD=0.85
CLARITY_THRESHOLD=0.85
COMPLETENESS_THRESHOLD=0.85
